# Backend build artifacts and local data
backend/data/*.db
backend/api
*.exe
*.test

# Go toolchain/module caches (never commit)
.go/

# Frontend dependencies and build outputs
node_modules/
dist/
*.local
playwright-report/
test-results/
blob-report/

# Capacitor / mobile platform build artifacts
frontend/android/.gradle/
frontend/android/.idea/
frontend/android/local.properties
frontend/android/**/build/
frontend/android/**/captures/
# Capacitor-synced web assets (generated by `cap sync`)
frontend/android/app/src/main/assets/public/
frontend/android/app/src/main/assets/capacitor.config.json
frontend/ios/Pods/
frontend/ios/**/build/
# Capacitor-synced iOS web assets (generated by `cap sync`)
frontend/ios/App/App/public/

# Environment files (except example)
.env
.env.*
!.env.example

# IDE / OS / tooling
.idea/
.vscode/
.DS_Store
*.swp
*.swo

# Nested duplicate checkout if ever created
/dts-submission/


