{
  "name": "frontend",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "packageManager": "bun@1.3.8",
  "scripts": {
    "postinstall": "node ./scripts/apply-ios-native-patches.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "node ./node_modules/typescript/bin/tsc -p tsconfig.app.json && node ./node_modules/typescript/bin/tsc -p tsconfig.node.json",
    "check:svelte": "svelte-check --tsconfig ./tsconfig.app.json",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "test:coverage": "node ./node_modules/vitest/vitest.mjs run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "cap:sync": "bun run build && bunx cap sync",
    "cap:android": "bunx cap run android",
    "cap:ios": "bunx cap run ios",
    "cap:open:android": "bunx cap open android",
    "cap:open:ios": "bunx cap open ios",
    "cap:icons": "bunx capacitor-assets generate --ios --android",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@chromatic-com/storybook": "^5.1.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-svelte-csf": "^5.1.1",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/svelte-vite": "^10.3.3",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.5.0",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-v8": "3.2.4",
    "jsdom": "^29.0.0",
    "playwright": "^1.58.2",
    "storybook": "^10.3.3",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "svelte-dnd-action": "^0.9.69",
    "typescript": "~5.9.3",
    "vite": "6.3.5",
    "vitest": "3.2.4"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor-community/sqlite": "^8.0.0",
    "hash-wasm": "^4.12.0",
    "svelty-picker": "^6.1.6"
  }
}
