{
  "name": "frontend",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "packageManager": "bun@1.3.8",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "check": "node ./node_modules/svelte-check/bin/svelte-check --tsconfig ./tsconfig.app.json && node ./node_modules/typescript/bin/tsc -p tsconfig.node.json",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "cap:sync": "bun run build && bunx cap sync",
    "cap:android": "bunx cap run android",
    "cap:ios": "bunx cap run ios",
    "cap:open:android": "bunx cap open android",
    "cap:open:ios": "bunx cap open ios",
    "cap:icons": "bunx capacitor-assets generate --ios --android"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.0",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "svelte-dnd-action": "^0.9.69",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor-community/sqlite": "^7.0.1",
    "svelty-picker": "^6.1.6"
  }
}
